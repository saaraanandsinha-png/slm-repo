# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
build/
app/build/

# Local configuration file (sdk path, etc.) — never commit
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ / Android Studio IDE files
*.iml
.idea/caches/
.idea/libraries/
.idea/modules.xml
.idea/workspace.xml
.idea/navEditor.xml
.idea/assetWizardSettings.xml
.idea/deploymentTargetSelector.xml

# Keystore / signing secrets — NEVER commit these
*.jks
*.keystore
key.properties
release.properties
secrets.properties

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# macOS
.DS_Store

# Windows
Thumbs.db

# Environment secrets
.env
.envrc

# Python / training scripts
__pycache__/
*.py[cod]
*.egg-info/
.venv/
env/
venv/
*.ipynb_checkpoints/
training_data.jsonl
dist/
*.so
tempCodeRunnerFile.py
